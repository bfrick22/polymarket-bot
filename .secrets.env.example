# ============================================================
# Third-party API keys — loaded on top of .env
# Copy to .secrets.env and fill in real values.
# .secrets.env is gitignored; never commit it.
# ============================================================

# Anthropic API key for Phase 4 (news scanner, copy sanity gate, daily review).
# Get one at https://console.anthropic.com/
# If empty or missing, Phase 4 is disabled and the bot runs Phases 1-3 only.
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
