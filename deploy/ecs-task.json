{
  "family": "polymarket-bot",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::YOUR_ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::YOUR_ACCOUNT_ID:role/polymarket-bot-task-role",
  "containerDefinitions": [
    {
      "name": "polymarket-bot",
      "image": "YOUR_ACCOUNT_ID.dkr.ecr.eu-west-1.amazonaws.com/polymarket-bot:latest",
      "essential": true,
      "environment": [],
      "secrets": [
        { "name": "PRIVATE_KEY",                  "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:PRIVATE_KEY::" },
        { "name": "POLY_ADDRESS",                 "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:POLY_ADDRESS::" },

        { "name": "COPY_RATIO",                   "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:COPY_RATIO::" },
        { "name": "COPY_RATIO_SMALL",             "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:COPY_RATIO_SMALL::" },
        { "name": "MAX_TRADE_USD",                "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:MAX_TRADE_USD::" },
        { "name": "POLL_INTERVAL_SEC",            "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:POLL_INTERVAL_SEC::" },
        { "name": "RECENT_TRADES_LIMIT",          "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:RECENT_TRADES_LIMIT::" },
        { "name": "MIN_SHARES",                   "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:MIN_SHARES::" },
        { "name": "MIN_POSITION_USD",             "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:MIN_POSITION_USD::" },
        { "name": "MAX_EXPOSURE_PER_MARKET_USD",  "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:MAX_EXPOSURE_PER_MARKET_USD::" },
        { "name": "MIRROR_SELLS",                 "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:MIRROR_SELLS::" },
        { "name": "MARKET_KEYWORDS",              "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:MARKET_KEYWORDS::" },

        { "name": "ARB_ENABLED",                  "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:ARB_ENABLED::" },
        { "name": "ARB_POLL_INTERVAL_SEC",        "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:ARB_POLL_INTERVAL_SEC::" },
        { "name": "ARB_THRESHOLD",                "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:ARB_THRESHOLD::" },
        { "name": "ARB_MIN_EDGE",                 "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:ARB_MIN_EDGE::" },
        { "name": "ARB_MAX_BASKET_USD",           "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:ARB_MAX_BASKET_USD::" },
        { "name": "ARB_MIN_OUTCOMES",             "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:ARB_MIN_OUTCOMES::" },
        { "name": "ARB_MAX_OUTCOMES",             "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:ARB_MAX_OUTCOMES::" },

        { "name": "CRYPTO_5M_ENABLED",            "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:CRYPTO_5M_ENABLED::" },
        { "name": "CRYPTO_5M_POLL_INTERVAL_SEC",  "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:CRYPTO_5M_POLL_INTERVAL_SEC::" },
        { "name": "CRYPTO_5M_ASSETS",             "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:CRYPTO_5M_ASSETS::" },
        { "name": "CRYPTO_5M_MAX_TRADE_USD",      "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:CRYPTO_5M_MAX_TRADE_USD::" },
        { "name": "CRYPTO_5M_IMPULSE_BPS",        "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:CRYPTO_5M_IMPULSE_BPS::" },
        { "name": "CRYPTO_5M_IMPULSE_WINDOW_SEC", "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:CRYPTO_5M_IMPULSE_WINDOW_SEC::" },
        { "name": "CRYPTO_5M_NEUTRAL_BAND",       "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:CRYPTO_5M_NEUTRAL_BAND::" },
        { "name": "CRYPTO_5M_SPREAD_THRESHOLD",   "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:CRYPTO_5M_SPREAD_THRESHOLD::" },
        { "name": "CRYPTO_5M_MIN_SECONDS_LEFT",   "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:CRYPTO_5M_MIN_SECONDS_LEFT::" },

        { "name": "ANTHROPIC_API_KEY",            "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:ANTHROPIC_API_KEY::" },
        { "name": "PHASE4_ENABLED",               "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:PHASE4_ENABLED::" },
        { "name": "COPY_GATE_ENABLED",            "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:COPY_GATE_ENABLED::" },
        { "name": "COPY_GATE_MODEL",              "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:COPY_GATE_MODEL::" },
        { "name": "COPY_GATE_TIMEOUT_SEC",        "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:COPY_GATE_TIMEOUT_SEC::" },
        { "name": "COPY_GATE_FAIL_MODE",          "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:COPY_GATE_FAIL_MODE::" },
        { "name": "NEWS_SCAN_ENABLED",            "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:NEWS_SCAN_ENABLED::" },
        { "name": "NEWS_SCAN_MODEL",              "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:NEWS_SCAN_MODEL::" },
        { "name": "NEWS_SCAN_INTERVAL_MIN",       "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:NEWS_SCAN_INTERVAL_MIN::" },
        { "name": "NEWS_SCAN_AUTO_TRADE",         "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:NEWS_SCAN_AUTO_TRADE::" },
        { "name": "NEWS_SCAN_MAX_TRADE_USD",      "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:NEWS_SCAN_MAX_TRADE_USD::" },
        { "name": "NEWS_SCAN_MAX_TRADES_PER_CYCLE", "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:NEWS_SCAN_MAX_TRADES_PER_CYCLE::" },
        { "name": "DAILY_REVIEW_ENABLED",         "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:DAILY_REVIEW_ENABLED::" },
        { "name": "DAILY_REVIEW_MODEL",           "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:DAILY_REVIEW_MODEL::" },
        { "name": "DAILY_REVIEW_HOUR_UTC",        "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/config:DAILY_REVIEW_HOUR_UTC::" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/polymarket-bot",
          "awslogs-region": "eu-west-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "python -c \"import sys; sys.exit(0)\""],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 15
      }
    }
  ]
}
