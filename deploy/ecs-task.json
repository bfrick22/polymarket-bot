{
  "family": "polymarket-bot",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::YOUR_ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::YOUR_ACCOUNT_ID:role/polymarket-bot-task-role",
  "containerDefinitions": [
    {
      "name": "polymarket-bot",
      "image": "YOUR_ACCOUNT_ID.dkr.ecr.eu-west-1.amazonaws.com/polymarket-bot:latest",
      "essential": true,
      "environment": [
        { "name": "COPY_RATIO",        "value": "0.1" },
        { "name": "MAX_TRADE_USD",     "value": "50" },
        { "name": "POLL_INTERVAL_SEC", "value": "10" }
      ],
      "secrets": [
        {
          "name": "PRIVATE_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/PRIVATE_KEY"
        },
        {
          "name": "POLY_ADDRESS",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/POLY_ADDRESS"
        },
        {
          "name": "TARGET_TRADER",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:YOUR_ACCOUNT_ID:secret:polymarket-bot/TARGET_TRADER"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/polymarket-bot",
          "awslogs-region": "eu-west-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "python -c \"import sys; sys.exit(0)\""],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 15
      }
    }
  ]
}
