# ============================================================
# Polymarket Copy-Trading Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ----- Wallet credentials (REQUIRED) -----
# Your Polygon wallet private key (hex, with or without 0x prefix)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Your proxy wallet address from polymarket.com/settings
POLY_ADDRESS=0xYOUR_PROXY_WALLET_ADDRESS

# ----- Trader to copy (REQUIRED) -----
# Run: python scripts/lookup_trader.py coldmath  to find this address
TARGET_TRADER=0x594edb9112f526fa6a80b8f858a6379c8a2c1c11

# ----- Copy trading settings (optional — defaults shown) -----
# Fraction of target's trade to mirror when target's trade > MAX_TRADE_USD
COPY_RATIO=0.15
# Fraction of target's trade to mirror when target's trade <= MAX_TRADE_USD (small trades get more weight)
COPY_RATIO_SMALL=0.35

# Hard cap per trade in USD
MAX_TRADE_USD=20

# How often to poll for new trades (seconds)
POLL_INTERVAL_SEC=10

# How many recent trades to fetch on each poll (more = more accurate but slower)
RECENT_TRADES_LIMIT=40