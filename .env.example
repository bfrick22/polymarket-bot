# ============================================================
# Polymarket Copy-Trading Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ----- Wallet credentials (REQUIRED) -----
# Your Polygon wallet private key (hex, with or without 0x prefix)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Your proxy wallet address from polymarket.com/settings
POLY_ADDRESS=0xYOUR_PROXY_WALLET_ADDRESS

# ----- Traders to copy -----
# The roster lives in src/traders.json (not this file). Each entry is
# {"name": "...", "address": "0x..."}. Add/remove traders there; no env
# variable needed.
#
# Find a wallet address by username:
#   python scripts/lookup_trader.py <username>

# ----- Copy trading settings (Phase 1) -----
# Fraction of target's trade to mirror when target's trade > MAX_TRADE_USD
COPY_RATIO=0.10
# Fraction of target's trade to mirror when target's trade <= MAX_TRADE_USD
COPY_RATIO_SMALL=0.35
# Hard cap per copied trade in USD
MAX_TRADE_USD=50

# How often to poll each trader for new trades (seconds)
POLL_INTERVAL_SEC=10
# How many recent trades to fetch on each poll
RECENT_TRADES_LIMIT=40

# Polymarket exchange minimum order is 5 shares — lower these to participate
# in coldmath-style 1-7c longshots (previously filtered by a $1 USD floor).
MIN_SHARES=5
MIN_POSITION_USD=0.10

# Per-market exposure ceiling (prevents single-bucket concentration losses)
MAX_EXPOSURE_PER_MARKET_USD=5

# Mirror target SELLs proportionally to your held position
MIRROR_SELLS=true

# Optional comma-separated keyword filter for market titles.
# Empty string = copy every market the targets trade.
MARKET_KEYWORDS=weather,temperature,rain,snow,hurricane,tornado,precipitation,degrees,wind,flood,frost,hail,blizzard,drought

# ----- Phase 2 — Multi-outcome arbitrage scanner -----
ARB_ENABLED=true
ARB_POLL_INTERVAL_SEC=60
ARB_THRESHOLD=0.97
ARB_MIN_EDGE=0.015
ARB_MAX_BASKET_USD=20
ARB_MIN_OUTCOMES=3
ARB_MAX_OUTCOMES=30

# ----- Phase 3 — Ultra-short crypto scanner -----
# Uses Binance public WebSocket (no Binance account / API key required).
CRYPTO_5M_ENABLED=true
CRYPTO_5M_POLL_INTERVAL_SEC=5
CRYPTO_5M_ASSETS=BTC,XRP
CRYPTO_5M_MAX_TRADE_USD=1.0
CRYPTO_5M_IMPULSE_BPS=3.0
CRYPTO_5M_IMPULSE_WINDOW_SEC=5
CRYPTO_5M_NEUTRAL_BAND=0.10
CRYPTO_5M_SPREAD_THRESHOLD=0.97
CRYPTO_5M_MIN_SECONDS_LEFT=60

# ----- Phase 4 — Claude AI integrations -----
# API key: put ANTHROPIC_API_KEY in .secrets.env (see .secrets.env.example).
# If the key is missing, Phase 4 is disabled and the bot runs Phases 1-3 only.
PHASE4_ENABLED=true

# 4B — copy-trade sanity gate (Haiku 4.5)
COPY_GATE_ENABLED=true
COPY_GATE_MODEL=claude-haiku-4-5
COPY_GATE_TIMEOUT_SEC=3
COPY_GATE_FAIL_MODE=allow

# 4A — news-driven market discovery (Sonnet 4.6)
NEWS_SCAN_ENABLED=true
NEWS_SCAN_MODEL=claude-sonnet-4-6
NEWS_SCAN_INTERVAL_MIN=15
NEWS_SCAN_AUTO_TRADE=false
NEWS_SCAN_MAX_TRADE_USD=2
NEWS_SCAN_MAX_TRADES_PER_CYCLE=3

# 4C — daily review (Sonnet 4.6)
DAILY_REVIEW_ENABLED=true
DAILY_REVIEW_MODEL=claude-sonnet-4-6
DAILY_REVIEW_HOUR_UTC=6
